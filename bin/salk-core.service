[Unit]
Description=SALK Security Core - Llave de Anclaje y Sentinela
After=network.target

[Service]
Type=forking
WorkingDirectory=/home/salk/Documentos/albedrio security
ExecStartPre=/home/salk/Documentos/albedrio security/salk/salk_boot
ExecStart=/home/salk/Documentos/albedrio security/sentinela/sentinela
Restart=always
RestartSec=1

[Install]
WantedBy=multi-user.target
